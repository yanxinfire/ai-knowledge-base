{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Knowledge Item",
  "type": "object",
  "required": [
    "title",
    "url",
    "source",
    "summary"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "source": {
      "type": "string",
      "enum": ["github", "hackernews", "other"]
    },
    "description": {
      "type": "string"
    },
    "popularity": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "highlights": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "score": {
      "type": "number",
      "minimum": 1,
      "maximum": 10
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
